  "decision_gates": {
    "allow_incident_overview": "Allow a tenant-scoped incident overview when the role has incident view permission.",
    "allow_trace_view": "Allow redacted tenant-scoped trace inspection when the role has trace view permission.",
    "allow_approval_review": "Allow approval review or approval action when the role has approval permission and is not approving its own request.",
    "allow_budget_view": "Allow tenant-scoped budget inspection for finops role.",
    "allow_execution_boundary_view": "Allow tenant-scoped execution-boundary inspection for security or operator roles.",
    "allow_access_audit_view": "Allow tenant-scoped access audit inspection for security, tenant admin, or auditor roles.",
    "deny_unknown_role": "Deny when the subject role is not in the approved AOIS-P role catalog.",
    "deny_cross_tenant": "Deny when the resource tenant does not match the authenticated tenant and break-glass policy is not valid.",
    "deny_missing_permission": "Deny when the role does not include the requested resource action.",
    "deny_unredacted_sensitive": "Deny sensitive resource rendering when required redaction has not passed.",
    "deny_self_approval": "Deny approval actions submitted by the same subject who requested the action.",
    "allow_break_glass_limited_view": "Allow a tightly limited redacted incident view for an approved security break-glass context."
  },
