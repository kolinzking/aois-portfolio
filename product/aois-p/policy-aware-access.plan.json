  "source_notes": [
    {
      "source": "OWASP Authorization Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/Authorization_Cheat_Sheet.html",
      "date_checked": "2026-04-30",
      "supports": "Access design must enforce least privilege, deny by default, validate permissions on every request, and log authorization decisions"
    },
    {
      "source": "OWASP Authentication Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/Authentication_Cheat_Sheet.html",
      "date_checked": "2026-04-30",
      "supports": "Authentication design must avoid identity enumeration and require stronger checks for sensitive actions"
    },
    {
      "source": "OWASP Session Management Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/Session_Management_Cheat_Sheet.html",
      "date_checked": "2026-04-30",
      "supports": "Session identifiers should be high-entropy, meaningless to clients, renewed after privilege change, and protected from disclosure"
    },
    {
      "source": "OWASP Multi-Tenant Application Security Cheat Sheet",
      "url": "https://cheatsheetseries.owasp.org/cheatsheets/Multi_Tenant_Security_Cheat_Sheet.html",
      "date_checked": "2026-04-30",
      "supports": "Tenant context should be bound to authenticated identity and every resource lookup should validate tenant ownership"
    },
    {
      "source": "NIST SP 800-63B",
