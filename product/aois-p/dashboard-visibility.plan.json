  "decision_gates": {
    "show_incident_overview": "Show the incident overview when a normal incident update is the latest state.",
    "show_trace_timeline": "Show the trace timeline when trace state is the latest operator question.",
    "show_route_registry_state": "Show routing and registry decisions when model or tool exposure changed.",
    "show_workflow_state": "Show workflow and orchestration when checkpoint or loop state changed.",
    "show_autonomy_agent_state": "Show autonomy and agent state when mode or handoff state changed.",
    "show_approval_queue": "Show approvals when a human decision is pending or recorded.",
    "show_budget_risk": "Show budget panel when cost or reserve posture changes.",
    "show_execution_boundary": "Show execution-boundary decision when action staging or denial changes.",
    "show_stale_data_warning": "Warn when an event is older than the panel freshness budget.",
    "show_empty_state": "Show an empty dashboard state when no incidents are in scope.",
    "block_unredacted_payload": "Block rendering sensitive content when redaction failed.",
    "block_inaccessible_widget": "Block dashboard readiness when required accessibility checks fail.",
    "show_connection_loss_banner": "Show connection loss before panel-specific content when stream state is disconnected."
  },
