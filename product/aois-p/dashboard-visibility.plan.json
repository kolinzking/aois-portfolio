  "dashboard_panels": [
    {
      "panel_id": "incident_overview",
      "title": "Incident Overview",
      "source_phase": "phase0-phase6",
      "owner": "aois-p-ops",
      "primary_fields": ["incident_id", "severity", "summary", "current_status"],
      "update_events": ["incident_created", "incident_updated"],
      "empty_state": "No AOIS-P incidents in the selected window.",
      "stale_after_seconds": 60,
      "accessibility_label": "Incident overview panel"
    },
    {
      "panel_id": "trace_timeline",
      "title": "Trace Timeline",
      "source_phase": "phase6",
      "owner": "aois-p-observability",
      "primary_fields": ["trace_id", "span_count", "last_span", "duration_ms"],
      "update_events": ["trace_started", "trace_completed"],
      "empty_state": "No trace selected.",
      "stale_after_seconds": 30,
      "accessibility_label": "Trace timeline panel"
    },
    {
      "panel_id": "route_registry",
      "title": "Route And Registry",
      "source_phase": "phase7-v20-through-v21",
      "owner": "aois-p-platform",
      "primary_fields": ["route_decision", "registry_decision", "allowed_tools", "blocked_tools"],
      "update_events": ["route_decided", "registry_checked"],
      "empty_state": "No route or registry decision yet.",
      "stale_after_seconds": 45,
      "accessibility_label": "Route and registry decision panel"
    },
    {
      "panel_id": "workflow_orchestration",
      "title": "Workflow And Orchestration",
      "source_phase": "phase7-v22-through-v23",
      "owner": "aois-p-ops",
      "primary_fields": ["workflow_id", "checkpoint", "orchestration_decision", "next_action"],
      "update_events": ["workflow_checkpointed", "orchestration_decided"],
      "empty_state": "No workflow checkpoint yet.",
      "stale_after_seconds": 45,
      "accessibility_label": "Workflow and orchestration panel"
    },
    {
      "panel_id": "autonomy_agents",
      "title": "Autonomy And Agents",
      "source_phase": "phase7-v23.8-through-v24",
      "owner": "aois-p-ops",
      "primary_fields": ["autonomy_mode", "current_agent", "next_agent", "handoff_count"],
      "update_events": ["autonomy_changed", "agent_handoff"],
      "empty_state": "No active agent collaboration state.",
      "stale_after_seconds": 30,
      "accessibility_label": "Autonomy and agent state panel"
    },
    {
      "panel_id": "approvals",
      "title": "Approvals",
      "source_phase": "phase7-v21-through-v25",
      "owner": "aois-p-ops-lead",
      "primary_fields": ["approval_id", "requested_by", "risk_tier", "expires_at"],
      "update_events": ["approval_requested", "approval_recorded"],
      "empty_state": "No pending approvals.",
      "stale_after_seconds": 15,
      "accessibility_label": "Approval queue panel"
    },
    {
      "panel_id": "budget",
      "title": "Budget And Cost",
      "source_phase": "phase7-v20.1-through-v20.2",
      "owner": "aois-p-finops",
      "primary_fields": ["budget_status", "remaining_units", "route_cost", "waste_guard"],
      "update_events": ["budget_updated", "route_decided"],
      "empty_state": "No budget decision yet.",
      "stale_after_seconds": 60,
      "accessibility_label": "Budget and cost panel"
    },
    {
      "panel_id": "execution_boundaries",
      "title": "Execution Boundaries",
      "source_phase": "phase7-v25",
      "owner": "aois-p-security",
      "primary_fields": ["action_category", "boundary_decision", "execution_mode", "blocked_reason"],
      "update_events": ["execution_boundary_decided"],
      "empty_state": "No execution-boundary decision yet.",
      "stale_after_seconds": 30,
      "accessibility_label": "Execution boundary panel"
    }
