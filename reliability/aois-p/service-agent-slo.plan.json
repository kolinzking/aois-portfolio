  "dashboard_policy": {
    "service_slo_dashboard_required": true,
    "agent_slo_dashboard_required": true,
    "error_budget_dashboard_required": true,
    "burn_rate_dashboard_required": true,
    "user_impact_panel_required": true
  },
  "controls": {
    "official_docs_review_required": true,
    "sli_definitions_required": true,
    "slo_objectives_required": true,
    "error_budget_policy_required": true,
    "burn_rate_alerts_required": true,
    "dashboard_plan_required": true,
    "agent_quality_gate_required": true,
    "agent_safety_gate_required": true,
    "primary_aois_separation_required": true,
    "resource_usage_record_required": true
