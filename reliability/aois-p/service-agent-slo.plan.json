{
  "mode": "service_agent_slo_plan_no_runtime",
  "namespace": "aois-p",
  "slo_runtime_started": false,
  "metrics_backend_started": false,
  "alerting_runtime_started": false,
  "dashboard_runtime_started": false,
  "agent_runtime_started": false,
  "provider_call_made": false,
  "external_network_required_for_this_lesson": false,
  "approved_for_live_slo_monitoring": false,
  "slo_windows": {
    "primary_window_days": 30,
    "fast_burn_window_minutes": 5,
    "slow_burn_window_hours": 6,
    "reporting_window_days": 7
  },
  "service_slos": [
    {
      "name": "aois-p-api",
      "type": "service",
      "sli": "successful_request_ratio",
      "objective_percent": 99.0,
      "window_days": 30,
      "good_event": "successful HTTP response or expected client rejection",
      "total_event": "all non-healthcheck HTTP requests",
      "latency_sli": "p95_latency_ms_below_500",
      "error_budget_policy": "freeze_risky_changes_when_budget_exhausted",
      "burn_rate_alerts_required": true
    },
    {
      "name": "aois-p-incident-stream-consumer",
      "type": "service",
      "sli": "freshness_within_60s_ratio",
      "objective_percent": 99.0,
      "window_days": 30,
      "good_event": "incident event processed within 60 seconds",
      "total_event": "all incident events accepted by the stream",
      "latency_sli": "p95_processing_lag_seconds_below_60",
      "error_budget_policy": "pause_nonessential_consumers_when_budget_exhausted",
      "burn_rate_alerts_required": true
    }
  ],
  "agent_slos": [
    {
      "name": "aois-p-incident-agent",
      "type": "agent",
      "sli": "valid_recommendation_ratio",
      "objective_percent": 95.0,
      "window_days": 30,
      "good_event": "recommendation passes schema, safety, and usefulness checks",
      "total_event": "all incident recommendations produced",
      "latency_sli": "p95_recommendation_latency_ms_below_3000",
      "quality_gate_required": true,
      "safety_gate_required": true,
      "human_review_required_for_destructive_action": true,
      "provider_error_budget_required": true,
      "error_budget_policy": "route_to_human_review_when_budget_exhausted",
      "burn_rate_alerts_required": true
    }
  ],
  "required_slis": [
    "availability",
    "latency",
    "freshness",
    "agent_success",
    "agent_quality",
    "agent_safety"
  ],
  "alert_policy": {
    "burn_rate_alerts_required": true,
    "fast_burn_page_required": true,
    "slow_burn_ticket_required": true,
