    },
    {
      "stage_id": "rollout_evidence",
      "required_fields": ["sample_size_status", "rollout_evidence_status", "feature_flag_status"],
      "blocks_on_missing": true
    },
    {
      "stage_id": "delivery_decision",
      "required_fields": ["rollback_ready", "approval_status", "risk_status"],
      "blocks_on_missing": true
    }
  ],
  "decision_gates": {
    "allow_model_delivery_candidate": "Allow a model or behavior delivery candidate only when experiment design, versions, dataset, metrics, guardrails, rollout evidence, registry, release gate, flag, rollback, approval, and risk review pass.",
    "block_missing_hypothesis": "Block when the experiment does not document the intended behavior change and expected outcome.",
    "block_missing_baseline": "Block when the champion or baseline model version is missing.",
    "block_missing_candidate_version": "Block when the challenger or candidate model version is missing.",
    "block_missing_dataset_version": "Block when the evaluation dataset version is missing.",
    "block_offline_eval_failed": "Block when offline evaluation fails.",
    "block_metric_regression": "Block when quality, latency, or cost deltas violate the metric catalog.",
    "block_guardrail_regression": "Block when safety, policy, or tenant-isolation guardrails regress.",
    "hold_sample_size_insufficient": "Hold when rollout sample size is not sufficient for the decision.",
    "hold_missing_rollout_evidence": "Hold when rollout evidence is missing or incomplete.",
    "block_registry_incomplete": "Block when the model registry record is incomplete.",
    "block_release_gate_failed": "Block when the v28 release gate fails.",
    "hold_feature_flag_not_ready": "Hold when the feature flag is missing, unsafe, or not reversible.",
    "block_no_rollback": "Block when model rollback target is missing.",
    "block_missing_approval": "Block when model delivery approval is missing.",
    "hold_risk_review": "Hold when AI risk review is pending."
  },
