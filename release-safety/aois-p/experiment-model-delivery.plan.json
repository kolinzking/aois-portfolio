  "metric_catalog": [
    {
      "metric_id": "quality_score",
      "direction": "higher_is_better",
      "minimum_delta_for_candidate": 0.02,
      "blocks_on_regression": true
    },
    {
      "metric_id": "latency_p95_ms",
      "direction": "lower_is_better",
      "maximum_allowed_regression": 200,
      "blocks_on_regression": true
    },
    {
      "metric_id": "cost_per_1k_tokens",
      "direction": "lower_is_better",
      "maximum_allowed_regression": 0.05,
      "blocks_on_regression": true
    },
    {
      "metric_id": "safety_violation_rate",
      "direction": "lower_is_better",
      "maximum_allowed_value": 0,
      "blocks_on_regression": true
    },
    {
      "metric_id": "policy_regression_count",
      "direction": "lower_is_better",
      "maximum_allowed_value": 0,
      "blocks_on_regression": true
    },
    {
      "metric_id": "tenant_isolation_failures",
      "direction": "lower_is_better",
      "maximum_allowed_value": 0,
      "blocks_on_regression": true
    }
  ],
  "evidence_stages": [
    {
      "stage_id": "experiment_design",
      "required_fields": ["experiment_id", "hypothesis_status", "dataset_version"],
      "blocks_on_missing": true
    },
    {
      "stage_id": "offline_evaluation",
