  "pipeline_stages": [
    {
      "stage_id": "source_control",
      "description": "Confirm source revision, branch policy, and review state before building.",
      "required_inputs": ["change_id", "source_revision", "branch_status"],
      "blocks_on_failure": true
    },
    {
      "stage_id": "build_test",
      "description": "Run build, unit tests, integration tests, policy tests, and security checks.",
      "required_inputs": ["test_status", "policy_test_status", "security_scan_status"],
      "blocks_on_failure": true
    },
    {
      "stage_id": "package_attest",
      "description": "Produce artifact digest, provenance, signature, and verification evidence.",
      "required_inputs": ["artifact_digest", "provenance_status", "signature_status"],
      "blocks_on_failure": true
    },
    {
      "stage_id": "release_gate",
      "description": "Require environment approval and release evidence before rollout.",
      "required_inputs": ["environment_approval", "release_evidence"],
      "blocks_on_failure": true
    },
    {
      "stage_id": "rollout_control",
      "description": "Control rollout strategy, health checks, rollback readiness, model rollout, and feature flags.",
      "required_inputs": [
        "rollout_strategy",
        "health_status",
        "rollback_ready",
        "model_rollout_status",
        "feature_flag_status"
      ],
      "blocks_on_failure": true
    }
  ],
  "decision_gates": {
    "allow_release_candidate": "Allow a release candidate only when source, tests, policy checks, scans, provenance, signature, approval, rollout, model, and flag controls pass.",
    "block_unreviewed_branch": "Block when branch policy or source review has not passed.",
    "block_workflow_overprivileged": "Block when workflow permissions are broader than the release job requires.",
    "block_dependency_review_failed": "Block when dependency review fails or unresolved dependency risk exists.",
    "block_tests_failed": "Block when build, unit, integration, dashboard, or access-policy regression checks fail.",
    "block_policy_tests_failed": "Block when AOIS policy, tenancy, redaction, approval, or execution-boundary tests fail.",
    "block_security_scan_failed": "Block when release security checks fail.",
    "block_missing_digest": "Block when the artifact digest is missing.",
    "block_missing_provenance": "Block when build provenance is missing or incomplete.",
    "block_unsigned_artifact": "Block when the artifact lacks expected signature evidence.",
    "block_signature_unverified": "Block when signature verification fails.",
    "block_missing_environment_approval": "Block when the release lacks required environment approval.",
    "hold_rollout_health": "Hold rollout when health checks are degraded or unknown.",
    "block_no_rollback": "Block when rollback plan or rollback target is missing.",
    "hold_model_rollout": "Hold when model rollout control is not staged, measured, or reversible.",
    "hold_feature_flag": "Hold when feature flag configuration is missing, unsafe, or not reversible."
  },
  "case_defaults": {
    "branch_status": "reviewed",
    "workflow_permissions": "least_privilege",
    "dependency_review": "pass",
    "test_status": "pass",
    "policy_test_status": "pass",
