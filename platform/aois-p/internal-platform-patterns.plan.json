  "interface_catalog": [
    {
      "interface_type": "portal",
      "contract": "developer_portal_entry",
      "requires_docs": true,
      "requires_owner": true
    },
    {
      "interface_type": "api",
      "contract": "openapi_or_resource_schema",
      "requires_docs": true,
      "requires_owner": true
    },
    {
      "interface_type": "template",
      "contract": "golden_path_template",
      "requires_docs": true,
      "requires_owner": true
    },
    {
      "interface_type": "cli",
      "contract": "thin_client_over_platform_api",
      "requires_docs": true,
      "requires_owner": true
    }
  ],
  "decision_gates": {
    "allow_self_service_capability": "Allow the self-service platform capability when catalog, owner, docs, API, template, policy, security, cost, observability, release, model delivery, tenant, approval, support, and lifecycle checks pass.",
    "block_unknown_capability": "Block when the requested capability is not in the platform catalog.",
    "block_deprecated_capability": "Block when the capability lifecycle is deprecated or retired without an approved migration path.",
    "block_missing_owner": "Block when a platform capability has no accountable owner.",
    "block_missing_docs": "Block when documentation and onboarding guidance are missing.",
    "block_missing_api_contract": "Block when the platform API or resource contract is missing.",
    "block_missing_template": "Block when the golden path template is missing.",
    "block_policy_boundary": "Block when policy defaults or policy boundaries are missing.",
    "block_security_boundary": "Block when security boundaries are missing or unsafe.",
    "hold_cost_review": "Hold when cost or quota review is pending.",
    "block_observability_missing": "Block when observability wiring or dashboard contracts are missing.",
    "block_release_integration_missing": "Block when the capability is not integrated with v28 release controls.",
    "hold_model_delivery_integration": "Hold when a model-related capability lacks v29 model-delivery tracking.",
    "block_tenant_boundary_missing": "Block when tenant or permission boundaries are missing.",
    "block_approval_missing": "Block when a capability that requires approval lacks an approval record.",
    "hold_support_slo_missing": "Hold when support ownership or support SLO is missing."
  },
  "case_defaults": {
    "capability_id": "aois_service_starter",
    "user_persona": "product_engineer",
    "request_type": "create_service",
