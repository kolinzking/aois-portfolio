    "support_slo_status": "defined",
    "lifecycle_status": "active"
  },
  "platform_cases": [
    {
      "case_id": "platform-v30-001",
      "name": "self_service_service_starter_allowed",
      "expected_decision": "allow_self_service_capability",
      "expected_operator_action": "publish_self_service_capability",
      "expected_platform_state": "available"
    },
    {
      "case_id": "platform-v30-002",
      "name": "unknown_capability_blocked",
      "overrides": {"capability_id": "unregistered_gpu_cluster"},
      "expected_decision": "block_unknown_capability",
      "expected_operator_action": "register_capability_or_reject_request",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-003",
      "name": "deprecated_capability_blocked",
      "overrides": {"lifecycle_status": "deprecated"},
      "expected_decision": "block_deprecated_capability",
      "expected_operator_action": "route_to_supported_capability",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-004",
      "name": "missing_owner_blocked",
      "overrides": {"owner": ""},
      "expected_decision": "block_missing_owner",
      "expected_operator_action": "assign_platform_owner",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-005",
      "name": "missing_docs_blocked",
      "overrides": {"documentation_status": "missing"},
      "expected_decision": "block_missing_docs",
      "expected_operator_action": "write_onboarding_docs",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-006",
      "name": "missing_api_contract_blocked",
      "overrides": {"api_contract_status": "missing"},
      "expected_decision": "block_missing_api_contract",
      "expected_operator_action": "define_platform_api_contract",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-007",
      "name": "missing_template_blocked",
      "overrides": {"template_status": "missing"},
      "expected_decision": "block_missing_template",
      "expected_operator_action": "create_golden_path_template",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-008",
      "name": "policy_boundary_blocked",
      "overrides": {"policy_status": "fail"},
      "expected_decision": "block_policy_boundary",
      "expected_operator_action": "repair_policy_defaults",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-009",
      "name": "security_boundary_blocked",
      "overrides": {"security_status": "fail"},
      "expected_decision": "block_security_boundary",
      "expected_operator_action": "repair_security_boundary",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-010",
      "name": "cost_review_pending_held",
      "overrides": {"cost_status": "pending"},
      "expected_decision": "hold_cost_review",
      "expected_operator_action": "complete_cost_and_quota_review",
      "expected_platform_state": "held"
    },
    {
      "case_id": "platform-v30-011",
      "name": "observability_missing_blocked",
      "overrides": {"observability_status": "missing"},
      "expected_decision": "block_observability_missing",
      "expected_operator_action": "add_observability_contract",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-012",
      "name": "release_integration_missing_blocked",
      "overrides": {"release_integration_status": "missing"},
      "expected_decision": "block_release_integration_missing",
      "expected_operator_action": "connect_v28_release_controls",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-013",
      "name": "model_delivery_integration_pending_held",
      "overrides": {
        "capability_id": "model_delivery_bundle",
        "model_delivery_status": "missing",
        "approval_status": "approved"
      },
      "expected_decision": "hold_model_delivery_integration",
      "expected_operator_action": "connect_v29_model_delivery_tracking",
      "expected_platform_state": "held"
    },
    {
      "case_id": "platform-v30-014",
      "name": "tenant_boundary_missing_blocked",
      "overrides": {"tenant_boundary_status": "missing"},
      "expected_decision": "block_tenant_boundary_missing",
      "expected_operator_action": "define_tenant_and_permission_boundaries",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-015",
      "name": "approval_missing_blocked",
      "overrides": {
        "capability_id": "environment_request",
        "approval_status": "missing"
      },
      "expected_decision": "block_approval_missing",
      "expected_operator_action": "request_platform_capability_approval",
      "expected_platform_state": "blocked"
    },
    {
      "case_id": "platform-v30-016",
      "name": "support_slo_missing_held",
      "overrides": {"support_slo_status": "missing"},
      "expected_decision": "hold_support_slo_missing",
      "expected_operator_action": "define_support_slo",
      "expected_platform_state": "held"
    }
