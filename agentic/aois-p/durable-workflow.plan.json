{
  "mode": "durable_agent_workflow_plan_no_runtime",
  "version": "v22",
  "namespace": "aois-p",
  "topic": "Durable agent workflow planning",
  "agent_runtime_started": false,
  "workflow_runtime_started": false,
  "mcp_server_started": false,
  "tool_calls_executed": false,
  "provider_call_made": false,
  "external_network_required_for_this_lesson": false,
  "durable_store_created": false,
  "persistent_storage_created": false,
  "approved_for_live_workflow": false,
  "primary_aois_excluded": true,
  "source_notes": [
    {
      "source": "Temporal documentation",
      "url": "https://docs.temporal.io/",
      "date_checked": "2026-04-29",
      "supports": "Durable workflow execution resumes from recorded progress after failures or interruptions"
    },
    {
      "source": "LangGraph durable execution documentation",
      "url": "https://docs.langchain.com/oss/python/langgraph/durable-execution",
      "date_checked": "2026-04-29",
      "supports": "Checkpointed graph execution supports pause, resume, human-in-the-loop, and recovery behavior"
    },
    {
      "source": "Model Context Protocol specification",
      "url": "https://modelcontextprotocol.io/specification/",
      "date_checked": "2026-04-29",
      "supports": "Workflow tool steps must preserve MCP host, server, and tool boundaries from v21"
    }
  ],
  "workflow_scope": {
    "aois_p_only": true,
    "primary_aois_excluded": true,
    "uses_v20_2_route_decisions": true,
    "uses_v21_tool_registry_results": true,
    "deterministic_plan_only": true,
    "durable_state_required": true,
    "checkpoint_required": true,
    "approval_wait_required": true,
    "idempotency_key_required": true,
    "retry_policy_required": true,
    "timeout_policy_required": true,
    "compensation_policy_required": true,
    "audit_log_required": true,
    "no_live_workflow_runtime": true,
    "no_tool_execution": true,
    "no_provider_call": true
  },
  "required_controls": {
    "state_machine_required": true,
    "step_owners_required": true,
    "step_inputs_outputs_required": true,
    "checkpoint_every_step": true,
    "approval_gate_required": true,
    "pause_resume_model_required": true,
    "retry_budget_required": true,
    "idempotency_required": true,
    "timeout_required": true,
    "failure_recovery_path_required": true,
    "terminal_status_required": true,
    "trace_id_required": true,
    "cost_context_required": true,
    "registry_context_required": true,
    "primary_aois_separation_required": true,
    "resource_usage_record_required": true,
    "source_currency_recorded": true
  },
  "workflow_dimensions": [
    "workflow_id",
    "incident_id",
    "trace_id",
    "route_decision",
    "registry_decision",
    "state",
    "current_step",
    "checkpoint_id",
    "idempotency_key",
    "retry_count",
    "timeout_seconds",
    "approval_status",
    "planned_tools",
    "blocked_tools",
    "cost_budget_remaining",
    "terminal_status",
    "recovery_action"
  ],
  "state_machine": {
    "initial_state": "received",
    "terminal_states": ["completed", "blocked", "failed", "timed_out"],
    "states": [
      "received",
      "route_selected",
      "registry_checked",
      "waiting_for_approval",
      "evidence_planned",
      "evidence_recorded",
      "answer_prepared",
      "completed",
      "blocked",
      "failed",
      "timed_out"
    ],
    "transitions": [
      {
        "from": "received",
        "to": "route_selected",
        "reason": "budget route selected"
      },
      {
        "from": "route_selected",
        "to": "registry_checked",
        "reason": "tool registry evaluated"
      },
      {
        "from": "registry_checked",
        "to": "waiting_for_approval",
        "reason": "sensitive tool requires approval"
      },
      {
        "from": "waiting_for_approval",
        "to": "evidence_planned",
        "reason": "approval granted"
      },
      {
        "from": "registry_checked",
        "to": "evidence_planned",
        "reason": "read-only tools allowed or no tools requested"
      },
      {
        "from": "registry_checked",
        "to": "blocked",
        "reason": "registry denied tool exposure"
      },
      {
        "from": "evidence_planned",
        "to": "evidence_recorded",
        "reason": "planned evidence recorded without tool execution"
      },
      {
        "from": "evidence_recorded",
        "to": "answer_prepared",
        "reason": "answer context is complete"
      },
      {
        "from": "answer_prepared",
        "to": "completed",
        "reason": "workflow closed with terminal checkpoint"
      },
      {
        "from": "*",
        "to": "timed_out",
        "reason": "step timeout exceeded"
      },
      {
        "from": "*",
        "to": "failed",
        "reason": "retry budget exhausted"
      }
    ]
  },
  "step_catalog": [
    {
      "step_id": "receive_incident",
      "owner": "aois-p-api",
      "input_refs": ["incident_message", "source"],
      "output_refs": ["incident_id", "trace_id"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id",
      "timeout_seconds": 5,
      "max_retries": 0,
      "compensation": "none"
    },
    {
      "step_id": "select_budget_route",
      "owner": "aois-p-router",
      "input_refs": ["incident_id", "trace_id", "cost_context"],
      "output_refs": ["route_decision", "route_id", "remaining_budget_units"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id:route",
      "timeout_seconds": 10,
      "max_retries": 1,
      "compensation": "mark_route_unselected"
    },
    {
      "step_id": "check_tool_registry",
      "owner": "aois-p-tool-governance",
      "input_refs": ["route_decision", "route_id", "requested_tools"],
      "output_refs": ["registry_decision", "allowed_tools", "blocked_tools"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id:registry",
      "timeout_seconds": 10,
      "max_retries": 1,
      "compensation": "clear_tool_plan"
    },
    {
      "step_id": "wait_for_approval",
      "owner": "aois-p-human-operator",
      "input_refs": ["registry_decision", "approval_required_for"],
      "output_refs": ["approval_status", "approval_actor", "approval_time"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id:approval",
      "timeout_seconds": 3600,
      "max_retries": 0,
      "compensation": "mark_approval_expired"
    },
    {
      "step_id": "record_evidence_plan",
      "owner": "aois-p-agent-runtime",
      "input_refs": ["allowed_tools", "route_id"],
      "output_refs": ["planned_tools", "tool_calls_executed"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id:evidence-plan",
      "timeout_seconds": 20,
      "max_retries": 2,
      "compensation": "discard_duplicate_evidence_plan"
    },
    {
      "step_id": "prepare_answer",
      "owner": "aois-p-agent-runtime",
      "input_refs": ["incident_id", "planned_tools", "blocked_tools"],
      "output_refs": ["summary", "recommended_action"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id:answer",
      "timeout_seconds": 20,
      "max_retries": 1,
      "compensation": "mark_answer_unprepared"
    },
    {
      "step_id": "close_workflow",
      "owner": "aois-p-api",
      "input_refs": ["summary", "recommended_action", "terminal_status"],
      "output_refs": ["closed_at", "final_checkpoint_id"],
      "checkpoint_required": true,
      "idempotency_key_ref": "incident_id:close",
      "timeout_seconds": 5,
      "max_retries": 1,
      "compensation": "none"
    }
  ],
  "decision_gates": {
    "complete_no_tool_workflow": "No tools are requested, so the workflow records the route and closes.",
    "complete_read_only_workflow_plan": "Read-only tools are allowed by registry policy and recorded as a plan only.",
    "pause_for_human_approval": "A sensitive tool is allowed but cannot continue until approval is recorded.",
    "resume_after_approval": "A paused workflow resumes from the approval checkpoint.",
    "block_registry_denial": "The registry blocked the requested tool exposure.",
    "recover_after_retry": "A transient step failure is retried within the retry budget.",
    "fail_timeout": "A step exceeded its timeout and the workflow records a terminal timed-out state.",
    "skip_duplicate_step": "A duplicate idempotency key is detected and the completed step is not repeated."
  },
