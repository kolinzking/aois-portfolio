  "source_notes": [
    {
      "source": "LangGraph overview",
      "url": "https://docs.langchain.com/oss/python/langgraph/overview",
      "date_checked": "2026-04-29",
      "supports": "LangGraph represents agent workflows as stateful graphs with persistence and human-in-the-loop support"
    },
    {
      "source": "LangGraph workflows and agents",
      "url": "https://docs.langchain.com/oss/python/langgraph/workflows-agents",
      "date_checked": "2026-04-29",
      "supports": "Agent and workflow orchestration can use routing, orchestrator-worker, evaluator-optimizer, and state-based control patterns"
    },
    {
      "source": "Temporal workflow definition documentation",
      "url": "https://docs.temporal.io/workflow-definition",
      "date_checked": "2026-04-29",
      "supports": "Workflow code must preserve deterministic execution and durable state semantics across replays"
    }
  ],
  "orchestration_scope": {
    "aois_p_only": true,
    "primary_aois_excluded": true,
    "uses_v20_2_route_decisions": true,
    "uses_v21_tool_registry_results": true,
    "uses_v22_workflow_state": true,
    "state_snapshot_required": true,
    "ordered_decision_rules_required": true,
    "loop_guard_required": true,
    "state_change_required": true,
    "stop_conditions_required": true,
    "approval_wait_respected": true,
    "registry_blocks_terminal": true,
    "budget_stop_required": true,
    "local_simulation_only": true,
    "no_live_orchestration_runtime": true,
    "no_tool_execution": true,
    "no_provider_call": true
  },
  "required_controls": {
    "state_schema_required": true,
    "decision_precedence_required": true,
    "max_iterations_required": true,
    "state_hash_required": true,
    "no_progress_stop_required": true,
    "terminal_state_stop_required": true,
    "approval_wait_stop_required": true,
    "registry_block_stop_required": true,
    "budget_reserve_required": true,
    "allowed_next_actions_required": true,
    "action_owner_required": true,
    "audit_event_required": true,
    "trace_id_required": true,
    "workflow_checkpoint_required": true,
    "primary_aois_separation_required": true,
    "resource_usage_record_required": true,
    "source_currency_recorded": true
  },
  "orchestration_dimensions": [
    "loop_id",
    "workflow_id",
    "incident_id",
    "trace_id",
    "current_state",
    "route_decision",
    "registry_decision",
    "approval_status",
    "iteration",
    "max_iterations",
    "state_hash",
    "state_changed",
    "budget_remaining_units",
    "next_action",
    "stop_reason",
    "audit_event",
    "terminal_status"
  ],
  "loop_policy": {
    "max_iterations": 5,
    "min_budget_reserve_units": 0.5,
    "state_change_required_between_iterations": true,
    "repeat_action_without_state_change": "stop_no_progress",
    "decision_precedence": [
      "stop_terminal_state",
      "stop_iteration_limit",
      "stop_no_progress",
      "stop_budget_reserve",
      "stop_registry_block",
      "wait_for_approval",
      "resume_after_approval",
      "plan_read_only_evidence",
      "prepare_answer",
      "close_workflow"
    ]
  },
  "allowed_next_actions": [
    {
      "action": "wait_for_approval",
      "owner": "aois-p-human-operator",
      "allowed_states": ["waiting_for_approval"],
      "audit_event": "orchestration.wait_for_approval",
      "executes_tool": false,
      "calls_provider": false
    },
    {
      "action": "record_evidence_plan",
      "owner": "aois-p-agent-runtime",
      "allowed_states": ["registry_checked", "waiting_for_approval"],
      "audit_event": "orchestration.record_evidence_plan",
      "executes_tool": false,
      "calls_provider": false
    },
    {
      "action": "prepare_answer",
      "owner": "aois-p-agent-runtime",
      "allowed_states": ["evidence_recorded"],
      "audit_event": "orchestration.prepare_answer",
      "executes_tool": false,
      "calls_provider": false
    },
    {
      "action": "close_workflow",
      "owner": "aois-p-api",
      "allowed_states": ["answer_prepared"],
      "audit_event": "orchestration.close_workflow",
      "executes_tool": false,
      "calls_provider": false
    },
    {
      "action": "stop",
      "owner": "aois-p-orchestrator",
      "allowed_states": ["completed", "blocked", "failed", "timed_out"],
      "audit_event": "orchestration.stop",
      "executes_tool": false,
      "calls_provider": false
    }
  ],
  "decision_gates": {
    "stop_terminal_state": "The workflow is already terminal and no further action is allowed.",
    "stop_iteration_limit": "The loop has reached the maximum iteration count.",
    "stop_no_progress": "The proposed action repeats without a state change.",
    "stop_budget_reserve": "Remaining budget is at or below the required reserve.",
    "stop_registry_block": "The registry decision blocked tool exposure.",
    "wait_for_approval": "The workflow is waiting for a required human approval.",
    "resume_after_approval": "Approval is granted and the next safe action is to record the evidence plan.",
    "plan_read_only_evidence": "Read-only tool exposure is allowed and the workflow needs an evidence plan.",
    "prepare_answer": "Evidence is recorded and the next safe action is answer preparation.",
    "close_workflow": "The answer is prepared and the workflow should close."
  },
