      "max_bytes": 5242880,
      "requires_accessibility_alternative": true,
      "requires_transcript": false,
      "primary_risks": ["embedded_text", "faces", "screenshots", "metadata"]
    },
    {
      "modality": "audio",
      "allowed_media_types": ["audio/wav", "audio/mpeg", "audio/ogg"],
      "max_bytes": 10485760,
      "requires_accessibility_alternative": false,
      "requires_transcript": true,
      "primary_risks": ["voice_identity", "background_speech", "transcription_error"]
    },
    {
      "modality": "video",
      "allowed_media_types": ["video/mp4", "video/webm"],
      "max_bytes": 52428800,
      "requires_accessibility_alternative": true,
      "requires_transcript": true,
      "primary_risks": ["faces", "screen_content", "audio_track", "temporal_context"]
    },
    {
      "modality": "document",
      "allowed_media_types": ["application/pdf", "image/tiff"],
      "max_bytes": 20971520,
      "requires_accessibility_alternative": false,
      "requires_transcript": true,
      "primary_risks": ["embedded_text", "pii", "tables", "layout_loss"]
    }
  ],
  "decision_gates": {
    "allow_image_analysis": "Allow image analysis when media intake, consent, redaction, accessibility alternative, evidence, route, policy, and confidence checks pass.",
    "allow_audio_analysis": "Allow audio analysis when validated media has consent, redaction, transcript, evidence, route, policy, and confidence checks.",
    "allow_video_analysis": "Allow video analysis when validated media has consent, redaction, accessibility alternative, transcript, evidence, route, policy, and confidence checks.",
    "allow_document_analysis": "Allow document analysis when validated media has consent, redaction, transcript or extracted text, evidence, route, policy, and confidence checks.",
    "block_unknown_modality": "Block when the input modality is not in the approved AOIS-P modality catalog.",
    "block_unsupported_media_type": "Block when media type is outside the modality allowlist.",
    "block_file_validation_failed": "Block when signature, extension, filename, or content validation fails.",
    "block_size_limit_exceeded": "Block when media exceeds the approved size limit.",
    "block_missing_consent": "Block when consent or lawful intake basis is missing.",
    "block_pii_unredacted": "Block when detected PII or sensitive media content is not redacted.",
    "block_missing_accessibility_alternative": "Block visual media when required text alternative or description is missing.",
    "block_missing_transcript": "Block time-based media or document extraction when transcript or text extraction is missing.",
    "block_cross_modal_mismatch": "Block when text, audio, visual, or document signals contradict each other without explanation.",
    "hold_missing_evidence": "Hold when the model answer cannot cite multimodal evidence.",
    "hold_low_confidence": "Hold when confidence is below the multimodal action threshold.",
    "route_to_text_fallback": "Route to text-only fallback when the multimodal provider is unavailable but an accessible fallback exists.",
    "block_policy_boundary": "Block when access, tenancy, safety, or release policy boundaries fail."
  },
