  "decision_gates": {
    "allow_observe_only_governed_record": "Allow an observe-only governed record when policy, target, data, privacy, telemetry, operator watch, red-team, release, and access checks pass.",
    "allow_draft_action_plan_only": "Allow a draft action plan when no computer action is executed and governance, evidence, and operator review controls pass.",
    "allow_synthetic_computer_use_plan_recorded": "Allow a synthetic computer-use plan record when the action is local, approved, previewed, budgeted, stoppable, rollback-ready, observable, red-team-cleared, release-approved, and access-approved.",
    "route_to_manual_operator": "Route to a human operator when governance permits the intent but computer-use execution should not proceed automatically.",
    "block_missing_governance_policy": "Block when governance policy, action intent, or action classification is missing.",
    "block_out_of_scope_environment": "Block when the environment is not in the approved local synthetic allowlist.",
    "block_live_target": "Block when the action targets a live, production, external, or authenticated environment.",
    "hold_pending_human_approval": "Hold when required human approval is missing.",
    "block_credential_request": "Block when credentials, secrets, tokens, password fields, or authenticated session handling would be required.",
    "block_sensitive_data_unredacted": "Block when sensitive screen data or action data is not redacted.",
    "block_high_impact_action": "Block high-impact actions such as safety-critical, legal, employment, health, financial, or irreversible decisions.",
    "block_external_transaction": "Block external transactions, submissions, purchases, messages, or commitments.",
    "hold_pending_safety_check": "Hold when a safety check is pending and needs human acknowledgement or review.",
    "hold_missing_step_preview": "Hold when the operator cannot inspect the proposed step before action.",
    "block_action_budget_exceeded": "Block when step, time, cost, loop, or rate budget is exceeded.",
    "block_missing_stop_control": "Block when the operator cannot immediately stop execution.",
    "block_missing_rollback": "Block when a state-changing action has no rollback plan.",
    "hold_missing_audit_trace": "Hold when trace, log, metric, or screen-evidence record is missing.",
    "block_unresolved_red_team_finding": "Block when v33 adversarial findings for the action surface are unresolved.",
    "block_release_gate": "Block when release approval is missing for the computer-use path.",
    "block_policy_boundary": "Block when access, tenancy, release, privacy, or safety policy boundaries fail."
  },
