  "decision_gates": {
    "allow_central_cloud_inference": "Allow central cloud inference when connectivity, residency, privacy, access, release, fallback, observability, update, and rollback controls pass.",
    "allow_edge_online_inference": "Allow edge online inference when a known device profile fits model size, memory, compute, power, latency, privacy, policy, release, observability, update, and rollback constraints.",
    "allow_offline_cached_inference": "Allow offline cached inference only when cache, freshness, sync, observability buffer, privacy, policy, update, and rollback controls are ready.",
    "block_unknown_device_profile": "Block when the edge target has no approved device profile.",
    "block_model_size_budget_exceeded": "Block when the model package exceeds the target device size budget.",
    "block_memory_budget_exceeded": "Block when projected memory use exceeds the device budget.",
    "hold_compute_budget_review": "Hold when CPU, GPU, NPU, or accelerator budget is unknown or unapproved.",
    "hold_power_budget_review": "Hold when the target is power-sensitive and the power budget is unknown or failed.",
    "block_latency_budget_exceeded": "Block when projected latency exceeds the target budget.",
    "hold_missing_offline_cache": "Hold offline execution when cache readiness is missing or incomplete.",
    "hold_stale_model": "Hold when the offline model freshness indicator is stale or unknown.",
    "block_data_residency_violation": "Block when inference placement would violate data residency constraints.",
    "block_privacy_unredacted": "Block when local or synced payloads are not redacted before inference.",
    "route_to_central_fallback": "Route to central cloud fallback when edge constraints fail but connectivity and central policy allow fallback.",
    "hold_observability_buffer_missing": "Hold when offline or degraded edge telemetry cannot be buffered safely.",
    "block_update_channel_missing": "Block when the deployment cannot receive approved model or policy updates.",
    "block_no_rollback": "Block when the edge deployment cannot roll back a bad model, policy, or runtime configuration.",
    "block_policy_boundary": "Block when access or release policy fails."
  },
